# Google OAuth — create credentials at https://console.cloud.google.com
# Authorized redirect URI: ${APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL of the app (no trailing slash)
# Local: http://localhost:3000
# Production: https://openexperiments.pages.dev
APP_URL=http://localhost:3000

# Cloudflare — found at dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
# API token: dash.cloudflare.com → My Profile → API Tokens
# Use "Edit Cloudflare Workers" template + add D1 Edit permission
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=
